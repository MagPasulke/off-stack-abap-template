# SAP ADT Connection (used by .opencode/tools/adt_gitpull.ts and adt_rununit.ts)
SAP_ADT_URL=https://your-sap-system:port
SAP_ADT_USER=DEVELOPER
SAP_ADT_PASSWORD=your-password-here

# Default package for adt_rununit & adt_gitpull (used when no target object is specified)
SAP_ROOT_PACKAGE=$YOUR_ROOT_PACKAGE_NAME
